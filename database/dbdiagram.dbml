Table assignment_allocated_markers {
  id bigint [pk]
  assignment_id bigint [not null]
  submission_id bigint [not null]
  student_id bigint [not null]
  marker_id bigint [not null]
  created_at timestamp
  updated_at timestamp

}

Table assignment_marks {
  id bigint [pk]
  assignment_id bigint [not null]
  submission_id bigint [not null]
  marker_id bigint [not null]
  score decimal
  feedback text
  workflow_state varchar [not null]
  created_at timestamp
  updated_at timestamp

}

Table assignment_overrides {
  id bigint [pk]
  assignment_id bigint [not null]
  user_id bigint
  course_group_id bigint
  available_from timestamp
  due_date timestamp
  cutoff_date timestamp
  max_attempts int
  reason varchar
  created_at timestamp
  updated_at timestamp

}

Table assignments {
  id bigint [pk]
  course_id bigint [not null]
  title varchar [not null]
  description text
  due_date timestamp [not null]
  max_score int [not null]
  is_active boolean [not null]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
  available_from timestamp
  cutoff_date timestamp
  max_attempts int [not null]
  allow_late_submission boolean [not null]
  submission_type varchar [not null]
