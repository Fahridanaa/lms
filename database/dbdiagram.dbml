  marker_count int [not null]
  multi_mark_method varchar
  anonymous_marking_enabled boolean [not null]
  hide_grader_from_student boolean [not null]

}

Table cache {
  key varchar [pk]
  value mediumtext [not null]
  expiration int [not null]
}

Table cache_locks {
  key varchar [pk]
  owner varchar [not null]
  expiration int [not null]
}

Table capabilities {
  id bigint [pk]
  name varchar [not null]
  shortname varchar [unique, not null]
