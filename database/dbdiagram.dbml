  file_path varchar [not null]
  mime_type varchar
  file_size bigint [not null]
  checksum varchar
  revision int [not null]
  visible boolean [not null]
  created_at timestamp
  updated_at timestamp

}

Table grade_categories {
  id bigint [pk]
  course_id bigint [not null]
  parent_id bigint
  name varchar [not null]
  depth int [not null]
  path varchar
  aggregation_method varchar [not null]
  weight decimal [not null]
  hidden boolean [not null]
  created_at timestamp
  updated_at timestamp
}

Table grade_category_histories {
  id bigint [pk]
  grade_category_id bigint [not null]
  action varchar
  old_name varchar
  new_name varchar
  old_weight decimal
  new_weight decimal
  old_hidden boolean
  new_hidden boolean
  old_aggregation_method varchar
  new_aggregation_method varchar
  old_parent_id bigint
  new_parent_id bigint
  changed_by bigint
  created_at timestamp
  updated_at timestamp

}

Table grade_histories {
  id bigint [pk]
  grade_id bigint [not null]
  action varchar
  old_score decimal
  new_score decimal
  old_percentage decimal
  new_percentage decimal
  old_status varchar
  new_status varchar
  old_feedback text
  new_feedback text
  changed_by bigint
  created_at timestamp
  updated_at timestamp

}

Table grade_item_histories {
  id bigint [pk]
  grade_item_id bigint [not null]
  action varchar
  old_name varchar
  new_name varchar
  old_max_score decimal
  new_max_score decimal
  old_pass_score decimal
  new_pass_score decimal
  old_weight decimal
  new_weight decimal
  old_hidden boolean
  new_hidden boolean
  old_locked boolean
  new_locked boolean
  old_category_id bigint
  new_category_id bigint
  changed_by bigint
  created_at timestamp
  updated_at timestamp

}

Table grade_items {
  id bigint [pk]
  course_id bigint [not null]
  item_type varchar
  item_id bigint
  name varchar [not null]
  max_score decimal [not null]
  pass_score decimal
  weight decimal [not null]
  hidden boolean [not null]
  locked boolean [not null]
